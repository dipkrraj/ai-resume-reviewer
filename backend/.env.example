# --- Security ---
SECRET_KEY=change-this-to-a-random-64-char-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Database ---
# Default: local SQLite, zero setup. Swap to Postgres for real deployment:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/resume_reviewer
DATABASE_URL=sqlite:///./resume_reviewer.db

# --- LLM ---
GROQ_API_KEY=your-key-here
LLM_MODEL=llama-3.3-70b-versatile

# --- Uploads ---
MAX_UPLOAD_MB=5
UPLOAD_DIR=./uploads

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:5173
